generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String         @unique
  name              String?
  role              Role           @default(SALES_EXECUTIVE)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  regionId          String?        @db.Uuid
  createdActivities Activity[]     @relation("ActivityCreator")
  updatedActivities Activity[]     @relation("ActivityUpdater")
  assignedClients   Client[]       @relation("ClientAssignee")
  createdClients    Client[]       @relation("ClientCreator")
  updatedClients    Client[]       @relation("ClientUpdater")
  assignedLeads     Lead[]         @relation("LeadAssignee")
  createdLeads      Lead[]         @relation("LeadCreator")
  updatedLeads      Lead[]         @relation("LeadUpdater")
  notifications     Notification[]
  assignedOrders    Order[]        @relation("OrderAssignee")
  createdOrders     Order[]        @relation("OrderCreator")
  updatedOrders     Order[]        @relation("OrderUpdater")
  region            Region?        @relation(fields: [regionId], references: [id])
}

model Region {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  clients   Client[]
  leads     Lead[]
  users     User[]
}

model Client {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String?
  phone          String?
  address        String?
  regionId       String?         @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assignedToId   String?         @db.Uuid
  companyName    String
  contactPerson  String?
  createdById    String?         @db.Uuid
  deletedAt      DateTime?
  gstNumber      String?         @unique
  paymentTerms   String?
  status         ClientStatus    @default(ACTIVE)
  updatedById    String?         @db.Uuid
  activities     Activity[]
  assignedTo     User?           @relation("ClientAssignee", fields: [assignedToId], references: [id])
  createdBy      User?           @relation("ClientCreator", fields: [createdById], references: [id])
  region         Region?         @relation(fields: [regionId], references: [id])
  updatedBy      User?           @relation("ClientUpdater", fields: [updatedById], references: [id])
  clientMappings ClientMapping[]
  leads          Lead[]
  orders         Order[]
}

model PipelineStage {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @unique
  order     Int       @default(0)
  color     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  leads     Lead[]
}

model Lead {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title               String
  expectedValue       Float?
  clientId            String        @db.Uuid
  assignedToId        String?       @db.Uuid
  stageId             String        @db.Uuid
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  createdById         String?       @db.Uuid
  deletedAt           DateTime?
  updatedById         String?       @db.Uuid
  description         String?
  expectedClosingDate DateTime?
  priority            LeadPriority  @default(MEDIUM)
  regionId            String?       @db.Uuid
  source              LeadSource    @default(OTHER)
  activities          Activity[]
  assignedTo          User?         @relation("LeadAssignee", fields: [assignedToId], references: [id])
  client              Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy           User?         @relation("LeadCreator", fields: [createdById], references: [id])
  region              Region?       @relation(fields: [regionId], references: [id])
  stage               PipelineStage @relation(fields: [stageId], references: [id])
  updatedBy           User?         @relation("LeadUpdater", fields: [updatedById], references: [id])
  orders              Order[]
}

model Order {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber      String            @unique @default(dbgenerated("substr(md5((random())::text), 0, 8)"))
  totalAmount      Float
  status           OrderStatus       @default(PENDING)
  leadId           String?           @db.Uuid
  clientId         String            @db.Uuid
  assignedToId     String?           @db.Uuid
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdById      String?           @db.Uuid
  deletedAt        DateTime?
  updatedById      String?           @db.Uuid
  activities       Activity[]
  assignedTo       User?             @relation("OrderAssignee", fields: [assignedToId], references: [id])
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy        User?             @relation("OrderCreator", fields: [createdById], references: [id])
  lead             Lead?             @relation(fields: [leadId], references: [id])
  updatedBy        User?             @relation("OrderUpdater", fields: [updatedById], references: [id])
  purchaseRequests PurchaseRequest[]
  items            OrderItem[]
}

model OrderItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @db.Uuid
  productId String   @db.Uuid
  quantity  Int
  price     Float    // Locked price at the time of order creation
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

model Activity {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        ActivityType @default(NOTE)
  description String
  createdById String       @db.Uuid
  clientId    String?      @db.Uuid
  leadId      String?      @db.Uuid
  orderId     String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  updatedById String?      @db.Uuid
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("ActivityCreator", fields: [createdById], references: [id], onDelete: Cascade)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  order       Order?       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  updatedBy   User?        @relation("ActivityUpdater", fields: [updatedById], references: [id])
  attachments Attachment[]
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  message   String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attachment {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileName   String
  fileUrl    String
  fileType   String?
  activityId String?   @db.Uuid
  createdAt  DateTime  @default(now())
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model PurchaseRequest {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String   @db.Uuid
  expectedLeadTime String?
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ClientMapping {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  spectrumClientId String
  sourceLocation   String
  sourceName       String?
  rawData          Json?
  unifiedClientId  String?       @db.Uuid
  status           MappingStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  client           Client?       @relation(fields: [unifiedClientId], references: [id])

  @@unique([spectrumClientId, sourceLocation])
}

model SkuMapping {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  spectrumSku    String
  sourceLocation String
  sourceName     String?
  rawData        Json?
  unifiedSku     String?
  status         MappingStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([spectrumSku, sourceLocation])
}

model FinancialRecord {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  location  String
  period    DateTime @db.Date
  revenue   Float
  expenses  Float
  profit    Float
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  REGIONAL_MANAGER
  SALES_EXECUTIVE
  DISPATCH
  ACCOUNTS
}

enum OrderStatus {
  PENDING
  PRODUCTION
  READY
  DISPATCHED
  DELIVERED
  CANCELLED
  PENDING_ACCOUNT_CREATION
  PENDING_DISPATCH_REVIEW
  READY_FOR_DISPATCH
  BACKORDERED
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum MappingStatus {
  PENDING
  MAPPED
  IGNORED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  EXISTING_CLIENT
  OTHER
}

model Product {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  category    String
  useCase     String?
  description String?
  price       Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  orderItems  OrderItem[]
}
